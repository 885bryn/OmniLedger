# Phase 21 Portainer production stack environment checklist.
# Set these in Portainer > Stacks > house-erp-prod > Environment variables.

# Required stack values (fail-fast if missing)
NAS_STATIC_IP=192.168.1.50
DB_PASSWORD=change_me_with_strong_secret
JWT_SECRET=change_me_with_a_long_random_secret
SESSION_SECRET=change_me_with_a_long_random_secret
HACT_ADMIN_EMAIL=admin@example.com

# Stable stack defaults (optional overrides)
FRONTEND_PORT=8085
BACKEND_PORT=8080
DB_NAME=hact_prod
DB_USER=postgres
STARTUP_DB_MAX_RETRIES=30
STARTUP_DB_RETRY_MS=2000

# Derived runtime mappings used by docker-compose.prod.yml
FRONTEND_ORIGIN=http://${NAS_STATIC_IP}:${FRONTEND_PORT}
API_URL=http://${NAS_STATIC_IP}:8085/api
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}
VITE_API_BASE_URL=/api
