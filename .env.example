# API runtime
PORT=8080
HOST=0.0.0.0
JWT_SECRET=change_me_with_a_long_random_secret

# PostgreSQL runtime
DB_NAME=hact_dev
DB_USER=postgres
DB_PASSWORD=change_me_local
DB_HOST=db
DB_PORT=5432

# Compose startup behavior
STARTUP_DB_MAX_RETRIES=30
STARTUP_DB_RETRY_MS=2000

# Connection string used by startup migration + runtime
DATABASE_URL=postgres://postgres:change_me_local@db:5432/hact_dev
