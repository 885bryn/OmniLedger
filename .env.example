# Portainer stack network contract (set these in Portainer > Stack > Environment variables)
NAS_STATIC_IP=192.168.1.50
FRONTEND_PORT=8085

# Frontend/backend production target hints derived from NAS_STATIC_IP
# Backend CORS resolver allows this origin in production when FRONTEND_ORIGIN is not explicitly set.
FRONTEND_ORIGIN=http://${NAS_STATIC_IP}:${FRONTEND_PORT}
# Frontend API base URL override (optional). Keep empty to derive from VITE_NAS_STATIC_IP.
VITE_API_BASE_URL=
# Frontend fallback NAS source for API base URL derivation.
VITE_NAS_STATIC_IP=${NAS_STATIC_IP}

# API runtime
PORT=8080
HOST=0.0.0.0
JWT_SECRET=change_me_with_a_long_random_secret
SESSION_SECRET=change_me_with_a_long_random_secret

# PostgreSQL runtime
DB_NAME=hact_dev
DB_USER=postgres
# Set via Portainer stack env (required in production startup validation).
DB_PASSWORD=change_me_with_strong_secret
DB_HOST=db
DB_PORT=5432

# Compose startup behavior
STARTUP_DB_MAX_RETRIES=30
STARTUP_DB_RETRY_MS=2000

# Connection string used by startup migration + runtime (must reference DB_PASSWORD value above)
DATABASE_URL=postgres://postgres:${DB_PASSWORD}@db:5432/hact_dev

# Admin bootstrap (set via Portainer stack env; used for production admin mapping)
HACT_ADMIN_EMAIL=
